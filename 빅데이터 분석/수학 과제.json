{"cells":[{"cell_type":"code","source":["a = int(input(\"첫번째 항 : \"))\n","b = int(input(\"공차 : \"))\n","c = int(input(\"항의 개수 : \"))\n","\n","sequence = [a+ b * i for i in range(c)]\n","\n","print(\"수열 : \",sequence)\n","\n","last_term = a+b*(c-1)\n","total = c*(a+last_term)//2\n","\n","print(f\"{c}번째 항: \",last_term)\n","print(\"합 : \",total)"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"ZM6-O6Jclxwk","executionInfo":{"status":"ok","timestamp":1749706565998,"user_tz":-540,"elapsed":25306,"user":{"displayName":"류현정","userId":"16795958861322054546"}},"outputId":"3c48a4a8-8cf0-4f24-a0c9-abd15e08ddca"},"id":"ZM6-O6Jclxwk","execution_count":15,"outputs":[{"output_type":"stream","name":"stdout","text":["첫번째 항 : 8\n","공차 : 5\n","항의 개수 : 6\n","수열 :  [8, 13, 18, 23, 28, 33]\n","6번째 항:  33\n","합 :  123\n"]}]},{"cell_type":"code","source":["import matplotlib.pyplot as plt\n","x = list(range(1,c+1))\n","y = sequence\n","\n","plt.plot(x,y,marker='o',linestyle='-',color='g')\n","plt.title(\"등차수업 그래프\")\n","plt.xlabel(\"항의 번호\")\n","plt.ylabel('항의 값')\n","plt.grid(True)\n","plt.show()"],"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":917},"id":"zdT1SpDHmj15","executionInfo":{"status":"ok","timestamp":1749706573282,"user_tz":-540,"elapsed":214,"user":{"displayName":"류현정","userId":"16795958861322054546"}},"outputId":"ad28e6c7-ac75-4d03-f847-ea702928bef8"},"id":"zdT1SpDHmj15","execution_count":16,"outputs":[{"output_type":"stream","name":"stderr","text":["/usr/local/lib/python3.11/dist-packages/IPython/core/pylabtools.py:151: UserWarning: Glyph 54637 (\\N{HANGUL SYLLABLE HANG}) missing from font(s) DejaVu Sans.\n","  fig.canvas.print_figure(bytes_io, **kw)\n","/usr/local/lib/python3.11/dist-packages/IPython/core/pylabtools.py:151: UserWarning: Glyph 51032 (\\N{HANGUL SYLLABLE YI}) missing from font(s) DejaVu Sans.\n","  fig.canvas.print_figure(bytes_io, **kw)\n","/usr/local/lib/python3.11/dist-packages/IPython/core/pylabtools.py:151: UserWarni